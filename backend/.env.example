# Security
SECRET_KEY=your_super_secret_jwt_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database
# For SQLite (local dev): sqlite:///./airs.db
# For PostgreSQL (production): postgresql://user:password@hostname:port/dbname
SQLALCHEMY_DATABASE_URL=sqlite:///./airs.db

# Environment
ENV=development
PORT=8000
